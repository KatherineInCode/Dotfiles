#!/usr/bin/env bash
# nwt — new work tree
#
# Finds the next available greek-letter iOS worktree (currently on its <letter>-parked
# branch with no existing tmux window), fetches the latest main, rebases the parked
# branch onto it, and opens a two-pane window in the correct alphabetical position
# among the other Greek-letter windows in the current tmux session.

set -euo pipefail

# shellcheck source=../includes/greek.bash
source "$(dirname "$(realpath "$0")")/../includes/greek.bash"
# shellcheck source=../includes/colors.bash
source "$(dirname "$(realpath "$0")")/../includes/colors.bash"

DEVELOPER="${HOME}/Developer"
MAIN_REPO="${DEVELOPER}/ios"

# --- helpers -----------------------------------------------------------------

info()  { printf "${Bold}${Blue}nwt:${Color_Off} %s\n" "$*"; }
err()   { printf "${Bold}${Red}nwt: error:${Color_Off} %s\n" "$*" >&2; }
fatal() { err "$*"; exit 1; }

window_exists() {
    local name="$1"
    tmux list-windows -t "$TMUX_SESSION" -F '#{window_name}' 2>/dev/null | grep -qxF "$name"
}

# Returns "<name> <char> <alphabet_index>" for the next available letter.
find_next_available() {
    local i
    for (( i = 0; i < ${#GREEK_NAMES[@]}; i++ )); do
        local name="${GREEK_NAMES[$i]}"
        local char="${GREEK_CHARS[$i]}"
        local dir="${DEVELOPER}/${name}-ios"

        [[ -d "$dir" ]] || continue

        local current_branch
        current_branch=$(git -C "$dir" rev-parse --abbrev-ref HEAD 2>/dev/null) || continue
        [[ "$current_branch" == "${name}-parked" ]] || continue

        # Skip if a window already exists for this letter (either naming convention)
        window_exists "${char} (Open)" && continue
        window_exists "${name} (Open)" && continue

        printf '%s %s %d' "$name" "$char" "$i"
        return 0
    done
    return 1
}

# Finds the tmux window index to insert after, so the new window lands in the
# correct alphabetical position among existing Greek-letter windows.
# Falls back to the index of 'iOS (Main)', then to end-of-list.
find_insert_after() {
    local letter_idx="$1"
    local insert_after=""

    # Walk open windows; track the highest tmux index belonging to a Greek letter
    # that precedes ours in the alphabet.
    local win_idx win_name
    while IFS= read -r line; do
        win_idx="${line%% *}"
        win_name="${line#* }"
        local j
        for (( j = 0; j < letter_idx; j++ )); do
            if [[ "$win_name" == "${GREEK_CHARS[$j]} "* ]]; then
                insert_after="$win_idx"
                break
            fi
        done
    done < <(tmux list-windows -t "$TMUX_SESSION" -F '#{window_index} #{window_name}')

    if [[ -n "$insert_after" ]]; then
        printf '%s' "$insert_after"
        return 0
    fi

    # No preceding Greek window found — insert after 'iOS (Main)'.
    local ios_idx
    ios_idx=$(tmux list-windows -t "$TMUX_SESSION" -F '#{window_index} #{window_name}' \
        | grep ' iOS (Main)$' | cut -d' ' -f1)
    printf '%s' "$ios_idx"
}

# --- main --------------------------------------------------------------------

main() {
    if [[ -z "${TMUX:-}" ]]; then
        fatal "not inside a tmux session"
    fi

    local TMUX_SESSION
    TMUX_SESSION=$(tmux display-message -p '#S')

    local result
    if ! result=$(find_next_available); then
        fatal "no available parked worktree found — all are in use or have open windows"
    fi

    local letter="${result%% *}"
    local rest="${result#* }"
    local char="${rest%% *}"
    local letter_idx="${rest##* }"
    local dir="${DEVELOPER}/${letter}-ios"
    local window_name="${char} (Open)"

    info "next available worktree: ${letter}-ios"

    # Fetch latest main (all worktrees share git objects, one fetch covers all)
    info "fetching origin/main..."
    git -C "$MAIN_REPO" fetch origin main

    # Rebase the parked branch onto the freshly fetched main
    info "rebasing ${letter}-parked onto origin/main..."
    if ! git -C "$dir" rebase origin/main; then
        err "rebase failed; aborting"
        git -C "$dir" rebase --abort 2>/dev/null || true
        exit 1
    fi

    # Insert the new window in the correct alphabetical slot
    info "opening window '${window_name}'..."
    local insert_after
    insert_after=$(find_insert_after "$letter_idx")

    if [[ -n "$insert_after" ]]; then
        tmux new-window -a -t "${TMUX_SESSION}:${insert_after}" -n "$window_name" -c "$dir"
    else
        tmux new-window -t "$TMUX_SESSION" -n "$window_name" -c "$dir"
    fi
    tmux split-window -h -c "$dir"
    tmux send-keys 'brew upgrade claude-code && clear && claude' Enter
    tmux select-pane -L

    info "ready — enjoy ${letter}-ios"
}

main "$@"
